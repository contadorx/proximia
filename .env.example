# Proximia — variaveis de ambiente
# Copie para .env.local e preencha com os dados do seu projeto Supabase.

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# Somente no servidor. Nunca versionar, nunca expor no browser.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Nome exibido da instancia enquanto o cadastro de organizacoes nao existe (F1).
NEXT_PUBLIC_APP_NOME=Proximia

# Envio de e-mail (extrato periódico). Sem estas variáveis, os envios ficam
# registrados como "simulado" e nada sai.
BREVO_API_KEY=
EMAIL_REMETENTE=extratos@seudominio.com.br
EMAIL_REMETENTE_NOME=Proximia

# Segredo da rotina diária de extratos. Sem ele, a rotina fica desligada.
CRON_SECRET=
